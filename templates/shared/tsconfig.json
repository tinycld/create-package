{
    "extends": "../tinycld-core/tsconfig.json",
    "compilerOptions": {
        "baseUrl": ".",
        "rootDir": "..",
        "paths": {
            "~/tinycld/{{PKG_SLUG}}/*": ["./tinycld/{{PKG_SLUG}}/*"],
            "@tinycld/core/*": ["../tinycld-core/tinycld/core/*"],
            "@tinycld/*": ["../tinycld-core/packages/@tinycld/*"],
            "~/*": ["../tinycld-core/*"]
        },
        "noEmit": true,
        "preserveSymlinks": false
    },
    "include": ["**/*.ts", "**/*.tsx", "../tinycld-core/**/*.d.ts", "../tinycld-core/expo-env.d.ts", "../tinycld-core/.expo/types/**/*.ts"],
    "exclude": ["node_modules", "server", "pb-migrations", "tests/**/*.spec.ts"]
}
