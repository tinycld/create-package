{
    "extends": "../tinycld/packages/@tinycld/core/tsconfig.json",
    "compilerOptions": {
        "baseUrl": ".",
        "rootDir": "..",
        "paths": {
            "~/tinycld/{{PKG_SLUG}}/*": ["./tinycld/{{PKG_SLUG}}/*"],
            "@tinycld/core/*": ["../tinycld/packages/@tinycld/core/*"],
            "~/*": ["../tinycld/packages/@tinycld/core/*"]
        },
        "noEmit": true,
        "preserveSymlinks": false
    },
    "include": [
        "**/*.ts",
        "**/*.tsx",
        "../tinycld/packages/@tinycld/core/**/*.d.ts"
    ],
    "exclude": ["node_modules", "server", "pb-migrations", "tests/**/*.spec.ts"]
}
